{
  "name": "cleanbook-bulgaria",
  "version": "1.0.0",
  "description": "CleanBook Bulgaria Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "module:create": "node scripts/create-module.js",
    "module:create:no-route": "node scripts/create-module.js --no-route",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node src/app/db/seed.ts",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alamin6688/cleanBook-bulgaria-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alamin6688/cleanBook-bulgaria-app.git/issues"
  },
  "homepage": "https://github.com/alamin6688/cleanBook-bulgaria-app.git#readme",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/node": "^25.0.8",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-status": "^2.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "prisma": "^6.19.2",
    "response-time": "^2.3.4",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.5"
