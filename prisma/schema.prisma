generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  CLEANER
  ADMIN
  SUPER_ADMIN
}

// Removed enums for PropertyType and ServiceType as they are now dynamic models.

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  email    String  @unique
  password String?

  phone           String? @unique
  role            Role    @default(CUSTOMER)
  language        String? @default("en")
  isEmailVerified Boolean @default(false)

  isActive            Boolean   @default(true)
  isBlocked           Boolean   @default(false)
  onboardingCompleted Boolean   @default(false)
  lastLogin           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  otpTokens       OtpToken[]
  refreshTokens   RefreshToken[]
  customerProfile CustomerProfile?
  cleanerProfile  CleanerProfile?

  customerBookings Booking[] @relation("CustomerBookings")
  cleanerBookings  Booking[] @relation("CleanerBookings")

  customerReviews Review[] @relation("CustomerReviews")
}

model CustomerProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String?
  profilePhoto String?

  // Location
  address   String?
  city      String?
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CleanerProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  displayName     String?
  bio             String?
  profilePhoto    String?
  yearsExperience Int?    @default(0)

  // Location
  address      String?
  city         String?
  latitude     Float?
  longitude    Float?
  serviceAreas String[] // ["Lozenets", "Mladost", "Center"]

  // Availability
  workingDays   String[] // ["Mon", "Tue", "Wed", "Thu"]
  workFrom      String? // "08:00"
  workTo        String? // "18:00"
  blockOffDates DateTime[]

  // Preferences
  propertyTypeIds      String[] @db.ObjectId
  additionalServiceIds String[] @db.ObjectId

  // Stats
  avgRating    Float @default(0)
  totalReviews Int   @default(0)
  totalJobs    Int   @default(0)

  services CleanerService[]
  reviews  Review[]
}

model CleanerService {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  cleanerProfileId String         @db.ObjectId
  cleanerProfile   CleanerProfile @relation(fields: [cleanerProfileId], references: [id], onDelete: Cascade)

  serviceCategoryId String          @db.ObjectId
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  name         String
  pricePerHour Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  bookingId String  @unique @db.ObjectId
  booking   Booking @relation(fields: [bookingId], references: [id])

  customerId String @db.ObjectId
  customer   User   @relation("CustomerReviews", fields: [customerId], references: [id])

  cleanerProfileId String         @db.ObjectId
  cleanerProfile   CleanerProfile @relation(fields: [cleanerProfileId], references: [id])

  rating      Float
  description String?
  tags        String[] // ["Punctual", "Thorough", "Polite", "Professional"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model PropertyCategory {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model ServiceCategory {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      String           @unique
  banner    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  services  CleanerService[]
  bookings  Booking[]
}

model AdditionalServiceCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceArea {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  postcodes String[] // e.g., ["1407", "1408"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETION_REQUESTED
  COMPLETE
  CANCELLED
  RESCHEDULE_REQUESTED
}

model Booking {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  customerId String @db.ObjectId
  customer   User   @relation("CustomerBookings", fields: [customerId], references: [id])

  cleanerId String @db.ObjectId
  cleaner   User   @relation("CleanerBookings", fields: [cleanerId], references: [id])

  propertyCategoryId String           @db.ObjectId
  propertyCategory   PropertyCategory @relation(fields: [propertyCategoryId], references: [id])

  serviceCategoryId String          @db.ObjectId
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  rooms     Int  @default(1)
  spaceSqft Int?

  date      DateTime
  startTime String // "HH:mm" format (24-hour)
  endTime   String // "HH:mm" format (24-hour)

  address   String?
  city      String?
  latitude  Float?
  longitude Float?

  specialInstructions String?

  charge         Float
  platformCharge Float
  totalCharge    Float

  paymentIntentId String? // Stripe Payment Intent ID
  status          BookingStatus @default(PENDING)
  paymentStatus   String        @default("PENDING") // PENDING, PAID, FAILED, REFUNDED

  // Reschedule Fields
  rescheduleDate      DateTime?
  rescheduleStartTime String?
  rescheduleEndTime   String?
  rescheduleReason    String?
  rescheduleNote      String?

  // Cancellation Fields
  cancelReason String?
  cancelNote   String?

  // Completion Evidence
  completionPhotos String[] @default([])
  completionNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review?
}

model OtpToken {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  otp       String
  purpose   OtpPurpose
  expiresAt DateTime
  used      Boolean    @default(false)
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
