generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  CLEANER
  ADMIN
  SUPER_ADMIN
}

// Removed enums for PropertyType and ServiceType as they are now dynamic models.

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String    @unique
  password        String?

  avatar          String?
  phone           String?   @unique
  name            String?
  role            Role      @default(CUSTOMER)
  language        String?   @default("en")
  isEmailVerified Boolean   @default(false)

  isActive        Boolean   @default(true)
  isBlocked       Boolean   @default(false)
  onboardingCompleted Boolean @default(false)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Location fields
  city            String?
  address         String?
  latitude        Float?
  longitude       Float?

  otpTokens      OtpToken[]
  refreshTokens  RefreshToken[]
  cleanerProfile CleanerProfile?


}

model CleanerProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic Info
  displayName     String?
  bio             String?
  profilePhoto    String?
  yearsExperience Int?    @default(0)

  // Location
  address      String?
  city         String?
  latitude     Float?
  longitude    Float?
  serviceAreas String[] // ["Lozenets", "Mladost", "Center"]

  // Availability
  workingDays   String[] // ["Mon", "Tue", "Wed", "Thu"]
  workFrom      String? // "08:00"
  workTo        String? // "18:00"
  workType      WorkType   @default(FULL_DAY)
  blockOffDates DateTime[]

  // Preferences
  propertyTypeIds String[] @db.ObjectId
  additionalServiceIds String[] @db.ObjectId

  // Stats
  avgRating    Float @default(0)
  totalReviews Int   @default(0)
  totalJobs    Int   @default(0)

  services CleanerService[]
}

model CleanerService {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  cleanerProfileId String         @db.ObjectId
  cleanerProfile   CleanerProfile @relation(fields: [cleanerProfileId], references: [id], onDelete: Cascade)

  serviceCategoryId String @db.ObjectId
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  
  name          String
  pricePerHour  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model PropertyCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  services  CleanerService[]
}

model AdditionalServiceCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceArea {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  postcodes String[] // e.g., ["1407", "1408"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WorkType {
  HALF_DAY
  FULL_DAY
  QUARTER_DAY
}

model OtpToken {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  otp       String
  purpose   OtpPurpose
  expiresAt DateTime
  used      Boolean    @default(false)
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
